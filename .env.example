# PostgreSQL connection string
DATABASE_URL="postgresql://scraper:password@localhost:5432/poznan_scraper?schema=public"

# API server port
PORT=3000

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Set to "true" in production to disable pino-pretty
LOG_PRETTY=true

# Max parallel portal crawls
CRAWLER_CONCURRENCY=4

# Max parallel detail fetches per run
DETAIL_FETCH_CONCURRENCY=2

# Playwright headless mode (true recommended for production)
PLAYWRIGHT_HEADLESS=true

# HTTP request timeout in milliseconds
REQUEST_TIMEOUT_MS=20000

# Custom user agent (leave empty to use default rotation)
USER_AGENT=

# Minimum delay between requests to the same portal (ms)
RATE_LIMIT_DELAY_MS=1500

# Maximum retries per request
MAX_RETRIES=3

# Node environment
NODE_ENV=production
