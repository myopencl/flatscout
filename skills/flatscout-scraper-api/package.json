{
  "name": "poznan-scraper-clawbot-skill",
  "version": "1.1.0",
  "description": "CLAWBOT skill for querying Poznań real estate market via poznan-scraper API",
  "main": "scripts/poznan-api.js",
  "scripts": {
    "search": "node scripts/search-listings.js",
    "create-search": "node scripts/create-search.js",
    "analyze": "node scripts/analyze-market.js",
    "api": "node scripts/poznan-api.js",
    "stats": "node scripts/stats.js",
    "manage": "node scripts/manage-listings.js",
    "bulk": "node scripts/bulk-operations.js",
    "parse-url": "node scripts/parse-url-to-search.js",
    "import-url": "node scripts/import-listing-from-url.js",
    "install-deps": "npm install node-fetch@2 minimist",
    "test": "npm run search -- --rooms 3 --limit 5"
  },
  "keywords": [
    "poznan",
    "real-estate",
    "scraper",
    "api",
    "property-search",
    "listing-state"
  ],
  "license": "MIT",
  "dependencies": {
    "minimist": "^1.2.8",
    "node-fetch": "^2.7.0",
    "pg": "^8.20.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
